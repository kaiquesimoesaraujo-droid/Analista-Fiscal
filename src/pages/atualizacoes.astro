---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import { updates } from "@data/updates";
import { legalById } from "@data/legal";
---

<BaseLayout title="Atualizações">
  <div class="container">
    <Breadcrumbs items={[{ title: "Atualizações" }]} />
    <header class="page-header">
      <p class="page-kicker">Monitoramento</p>
      <h1>Atualizações e alertas</h1>
      <p>Lista inicial dos pontos que precisam ser acompanhados em fonte oficial para manter o treinamento seguro.</p>
    </header>
    <div class="reference-grid">
      {updates.map((item) => {
        const source = legalById[item.sourceId];
        return (
          <article class="card">
            <span class="pill alert">{item.tag}</span>
            <h3>{item.title}</h3>
            <p><strong>{item.date}</strong> · {item.description}</p>
            <a href={source.url}>Fonte oficial: {source.title}</a>
          </article>
        );
      })}
    </div>
  </div>
</BaseLayout>
