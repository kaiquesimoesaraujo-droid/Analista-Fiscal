---
import BaseLayout from "@layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Página não encontrada">
  <div class="container">
    <header class="page-header">
      <p class="page-kicker">404</p>
      <h1>Página não encontrada</h1>
      <p>O conteúdo pode ter mudado de lugar durante a evolução da trilha.</p>
      <a class="primary-link" href={base}>Voltar para a Home</a>
    </header>
  </div>
</BaseLayout>
