---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import { modules } from "@data/modules";
---

<BaseLayout title="Checklists operacionais">
  <div class="container">
    <Breadcrumbs items={[{ title: "Checklists" }]} />
    <header class="page-header">
      <p class="page-kicker">Rotina fiscal</p>
      <h1>Checklists operacionais</h1>
      <p>Listas práticas extraídas dos módulos para usar em conferência de pagamentos, notas e fechamento.</p>
    </header>
    <div class="reference-grid">
      {modules.map((module) => (
        <article class="card">
          <span class="pill">Módulo {module.order}</span>
          <h3>{module.title}</h3>
          <ul class="checklist">
            {module.checklist.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
