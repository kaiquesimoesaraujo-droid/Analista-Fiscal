---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import { faqs } from "@data/faqs";
import { legalById } from "@data/legal";
---

<BaseLayout title="FAQ">
  <div class="container">
    <Breadcrumbs items={[{ title: "FAQ" }]} />
    <header class="page-header">
      <p class="page-kicker">Perguntas frequentes</p>
      <h1>FAQ fiscal</h1>
      <p>Respostas objetivas para dúvidas recorrentes da rotina tributária e de uso do portal.</p>
    </header>
    <div class="faq-list">
      {faqs.map((faq) => (
        <details class="card">
          <summary><strong>{faq.question}</strong></summary>
          <p>{faq.answer}</p>
          <div class="pill-row">
            {faq.references.map((id) => {
              const reference = legalById[id];
              return <a class="pill" href={reference.url}>{reference.title}</a>;
            })}
          </div>
        </details>
      ))}
    </div>
  </div>
</BaseLayout>
