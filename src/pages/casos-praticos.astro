---
import BaseLayout from "@layouts/BaseLayout.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import { caseStudies } from "@data/cases";
import { legalById } from "@data/legal";
---

<BaseLayout title="Casos práticos">
  <div class="container">
    <Breadcrumbs items={[{ title: "Casos práticos" }]} />
    <header class="page-header">
      <p class="page-kicker">Laboratório operacional</p>
      <h1>Estudos de caso práticos</h1>
      <p>Roteiros para analisar notas, contratos e obrigações com rastreabilidade de fonte oficial.</p>
    </header>
    <div class="case-grid">
      {caseStudies.map((study) => (
        <article class="case-panel">
          <span class="pill">{study.area}</span>
          <h3>{study.title}</h3>
          <p><strong>Cenário:</strong> {study.scenario}</p>
          <h4>Roteiro</h4>
          <ol>
            {study.route.map((step) => <li>{step}</li>)}
          </ol>
          <h4>Checklist</h4>
          <ul>
            {study.checklist.map((item) => <li>{item}</li>)}
          </ul>
          <p><strong>Validação:</strong> {study.validation}</p>
          <div class="pill-row">
            {study.references.map((id) => {
              const reference = legalById[id];
              return <a class="pill" href={reference.url}>{reference.title}</a>;
            })}
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
