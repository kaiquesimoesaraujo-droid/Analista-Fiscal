---
import BaseLayout from "@layouts/BaseLayout.astro";
import ModuleCard from "@components/ModuleCard.astro";
import { modules } from "@data/modules";
import { updates } from "@data/updates";
import { legalById } from "@data/legal";

const base = import.meta.env.BASE_URL.endsWith("/") 
  ? import.meta.env.BASE_URL 
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Home">
  <section class="dashboard-hero" style={`--hero-image: url("https://images.unsplash.com/photo-1554224154-26032ffc0d07?auto=format&fit=crop&w=1600&q=80")`}>
    <p class="eyebrow">Trilha fiscal e tributária brasileira</p>
    <h1>Estude retenções, documentos fiscais e reforma tributária com base oficial.</h1>
    <p>Portal estático, expansível e pronto para GitHub Pages, organizado para transformar legislação em rotina operacional segura.</p>
    <div class="hero-actions">
      <a class="primary-link" href={`${base}modulos/`}>Ver módulos</a>
      <a class="secondary-link" href={`${base}biblioteca-legal/`}>Abrir biblioteca legal</a>
    </div>
  </section>

  <section class="section container">
    <p class="page-kicker">Arquitetura do estudo</p>
    <h2>Aprendizagem por camadas</h2>
    <p class="section-lead">Comece pela base conceitual, avance pelas retenções e feche com documentos fiscais, SPED e Reforma Tributária. Cada módulo traz visão geral, fundamentos, exemplos, erros comuns, checklist, quiz e fontes oficiais.</p>
    <div class="grid modules">
      {modules.map((module) => <ModuleCard module={module} />)}
    </div>
  </section>

  <section class="section container">
    <div class="grid two">
      <article class="card">
        <h3>Regra de ouro</h3>
        <p>Quando uma operação depender de UF ou município, o portal sempre sinaliza a validação local. ICMS, ST, MVA, ISS e obrigações acessórias locais não devem ser fechados por regra genérica.</p>
      </article>
      <article class="card">
        <h3>Revisão permanente</h3>
        <p>Temas com transição, como IBS, CBS, IS, EFD 2026 e substituição da DIRF, aparecem marcados como pontos de atualização legislativa frequente.</p>
      </article>
    </div>
  </section>

  <section class="section container">
    <p class="page-kicker">Atualizações recentes</p>
    <h2>Pontos que mudaram ou exigem atenção</h2>
    <div class="reference-grid">
      {updates.slice(0, 4).map((item) => {
        const source = legalById[item.sourceId];
        return (
          <article class="card">
            <span class="pill alert">{item.tag}</span>
            <h3>{item.title}</h3>
            <p>{item.date} · {item.description}</p>
            <a href={source.url}>Fonte oficial: {source.title}</a>
          </article>
        );
      })}
    </div>
  </section>
</BaseLayout>
