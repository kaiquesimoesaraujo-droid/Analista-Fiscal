---
import { modules } from "@data/modules";
import { primaryPages } from "@data/site";

const base = import.meta.env.BASE_URL.endsWith("/") 
  ? import.meta.env.BASE_URL 
  : `${import.meta.env.BASE_URL}/`;
const currentPath = Astro.url.pathname.replace(base, "/");
const isActive = (href: string) => currentPath === href || (href !== "/" && currentPath.startsWith(href));
---

<aside class="sidebar" data-sidebar data-open="false" aria-label="Navegação principal">
  <section class="sidebar-section">
    <p class="sidebar-title">Portal</p>
    <ul class="nav-list">
      {primaryPages.map((item) => (
        <li><a class:list={["nav-link", { active: isActive(item.href) }]} href={`${base}${item.href.replace(/^\//, "")}`}>{item.title}</a></li>
      ))}
    </ul>
  </section>

  <section class="sidebar-section">
    <p class="sidebar-title">Módulos</p>
    <ul class="nav-list">
      {modules.map((module) => (
        <li>
          <a class:list={["nav-link", { active: currentPath === `/modulos/${module.slug}/` }]} href={`${base}modulos/${module.slug}/`}>
            {module.order}. {module.title}
          </a>
        </li>
      ))}
    </ul>
  </section>
</aside>
