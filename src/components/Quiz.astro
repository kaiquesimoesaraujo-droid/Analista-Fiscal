---
import type { QuizQuestion } from "@data/modules";

const { quiz, slug } = Astro.props as { quiz: QuizQuestion[]; slug: string };
---

<section class="quiz" data-quiz={slug}>
  <h2>Quiz do módulo</h2>
  <p class="section-lead">Responda e confira o gabarito comentado. As respostas não são enviadas a nenhum servidor.</p>
  {quiz.map((question, questionIndex) => (
    <fieldset data-answer={question.answer}>
      <legend>{questionIndex + 1}. {question.question}</legend>
      {question.options.map((option, optionIndex) => (
        <label>
          <input type="radio" name={`${slug}-${questionIndex}`} value={optionIndex} />
          <span>{option}</span>
        </label>
      ))}
      <p class="quiz-result" aria-live="polite"></p>
      <p class="section-lead">{question.explanation}</p>
    </fieldset>
  ))}
  <button class="primary-link" type="button" data-check-quiz>Conferir respostas</button>
</section>

<script>
  document.querySelectorAll("[data-quiz]").forEach((quiz) => {
    quiz.querySelector("[data-check-quiz]")?.addEventListener("click", () => {
      let score = 0;
      const fields = quiz.querySelectorAll("fieldset[data-answer]");
      fields.forEach((field) => {
        const answer = field.getAttribute("data-answer");
        const checked = field.querySelector("input:checked");
        const result = field.querySelector(".quiz-result");
        const ok = checked?.value === answer;
        if (ok) score += 1;
        if (result) result.textContent = ok ? "Correto." : "Revise a base legal indicada neste módulo.";
      });
      const label = quiz.querySelector("h2");
      if (label) label.textContent = `Quiz do módulo · ${score}/${fields.length}`;
    });
  });
</script>
