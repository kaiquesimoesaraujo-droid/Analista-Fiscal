---
import type { TrainingModule } from "@data/modules";

const { module } = Astro.props as { module: TrainingModule };
const base = import.meta.env.BASE_URL;
---

<a class="module-card" href={`${base}modulos/${module.slug}/`}>
  <img src={module.heroImage} alt={module.imageAlt} loading="lazy" />
  <div class="pill-row">
    <span class="pill">Módulo {module.order}</span>
    <span class="pill">{module.level}</span>
    {module.transitional && <span class="pill alert">Transição</span>}
  </div>
  <h3>{module.title}</h3>
  <p>{module.summary}</p>
</a>
