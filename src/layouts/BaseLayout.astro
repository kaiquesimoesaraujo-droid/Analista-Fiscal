---
import Header from "@components/Header.astro";
import Sidebar from "@components/Sidebar.astro";
import { site } from "@data/site";
import "@styles/global.css";

const { title = site.name, description = site.description } = Astro.props as { title?: string; description?: string };
const pageTitle = title === site.name ? title : `${title} · ${site.name}`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="preconnect" href="https://images.unsplash.com" />
  </head>
  <body>
    <a class="skip-link secondary-link" href="#conteudo">Ir para o conteúdo</a>
    <div class="app-shell">
      <Header />
      <div class="layout">
        <Sidebar />
        <main id="conteudo" class="content-area">
          <slot />
          <footer class="footer">
            <p>Conteúdo educacional. Valide operações reais com a legislação específica aplicável, atos estaduais/municipais e orientação profissional quando necessário.</p>
            <p>Última revisão geral: {site.lastReview}.</p>
          </footer>
        </main>
      </div>
    </div>
  </body>
</html>
